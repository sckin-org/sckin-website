{
  "$description": "SCKIN design tokens. Primitives + semantic aliases. Semantic layer is the only public API for components.",
  "color": {
    "red": {
      "50": "#F9EFF1",
      "100": "#EED3D8",
      "200": "#DCA6AF",
      "300": "#C4707E",
      "400": "#A93B4C",
      "500": "#8A1626",
      "600": "#71121F",
      "700": "#5A0E19",
      "800": "#430A12",
      "900": "#2E060C"
    },
    "gray": {
      "0": "#FFFFFF",
      "50": "#F7F7F8",
      "100": "#EFEFF1",
      "200": "#E2E2E5",
      "300": "#C8C8CD",
      "400": "#A3A3AA",
      "500": "#7D7D85",
      "600": "#5A5A61",
      "700": "#424248",
      "800": "#2A2A2E",
      "900": "#1B1B1E"
    }
  },
  "semantic": {
    "color": {
      "cta": "{color.red.500}",
      "ctaHover": "{color.red.600}",
      "ctaPressed": "{color.red.700}",
      "link": "{color.red.700}",
      "linkHover": "{color.red.500}",
      "surfacePage": "{color.gray.0}",
      "surfaceSubtle": "{color.gray.50}",
      "surfaceBand": "{color.red.500}",
      "surfaceFooter": "{color.gray.900}",
      "textHeading": "{color.gray.900}",
      "textBody": "{color.gray.600}",
      "textMuted": "{color.gray.500}",
      "textHeadingAccent": "{color.red.500}",
      "textBodyAccent": "{color.red.700}",
      "textOnBand": "#FFFFFF",
      "textOnBandMuted": "rgba(255,255,255,0.72)",
      "textOnFooterStrong": "#FFFFFF",
      "textOnFooter": "rgba(255,255,255,0.75)",
      "textOnFooterMuted": "rgba(255,255,255,0.50)",
      "borderSubtle": "{color.gray.200}",
      "borderStrong": "{color.gray.300}",
      "borderInput": "{color.gray.300}",
      "borderInputError": "{color.red.500}",
      "surfaceInputError": "{color.red.50}",
      "textError": "{color.red.600}",
      "surfaceChip": "{color.gray.100}",
      "textChip": "{color.gray.600}",
      "surfaceSelected": "{color.gray.900}",
      "textOnSelected": "#FFFFFF"
    }
  },
  "contrast": {
    "red.500 on white": "9.5:1 (AAA — AA-safe for small/body text; this is THE safe red stop on white)",
    "red.700 on white": "13.9:1 (AAA — links, pressed states)",
    "gray.600 on white": "6.8:1 (AA body)",
    "white on red.500": "9.5:1 (AAA)",
    "white on gray.900": "17.2:1 (AAA)"
  },
  "font": {
    "family": {
      "sans": "Inter"
    },
    "weight": {
      "regular": 400,
      "semibold": 600
    },
    "size": {
      "caption": 13,
      "small": 15,
      "body": 17,
      "bodyLg": 19,
      "h3": {
        "mobile": 22,
        "desktop": 28
      },
      "h2": {
        "mobile": 28,
        "desktop": 40
      },
      "h1": {
        "mobile": 36,
        "desktop": 56
      },
      "display": {
        "mobile": 44,
        "desktop": 72,
        "note": "hero headline capped at 72px on desktop"
      },
      "stat": {
        "mobile": 48,
        "desktop": 64
      },
      "statGoal": {
        "mobile": 68,
        "desktop": 96
      }
    },
    "lineHeight": {
      "tight": 1.15,
      "snug": 1.3,
      "body": 1.55
    },
    "tracking": {
      "tight": "-0.02em",
      "overline": "0.08em"
    }
  },
  "space": {
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 24,
    "6": 32,
    "7": 48,
    "8": 64,
    "9": 96,
    "10": 128
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 20,
    "pill": 980
  },
  "shadow": {
    "card": "0 4px 24px rgba(27,27,30,0.08)",
    "nav": "0 1px 0 rgba(27,27,30,0.06)"
  },
  "motion": {
    "duration": "400ms",
    "ease": "cubic-bezier(0.4,0,0.2,1)",
    "rise": "24px",
    "reducedMotion": "duration 0ms, rise 0px"
  },
  "breakpoint": {
    "tablet": 768,
    "desktop": 1200
  },
  "$note": "Brand red is #8A1626 (hemoglobin red). Approved by Zacharie 2026-07-22 at import review, superseding #C41E3A for the website. red.500 is the AA-safe stop for small text on white (9.5:1). Known off-token values in comps, kept deliberately: white-alpha overlays on red band / footer (band text tokens cover the canonical three), 980px pill radius (radius.pill), 44/54px hero mobile sizes map to font.size.display mobile stop."
}
