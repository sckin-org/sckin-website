{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard *)",
      "Bash(chmod 777 *)",
      "Read(.env*)",
      "Read(**/.env*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(gh repo delete*)",
      "Bash(aws *)",
      "Bash(npm publish*)",
      "Edit(.env*)",
      "Edit(**/.env*)",
      "Edit(amplify.yml)",
      "Bash(curl *)",
      "Bash(wget *)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(content/**)",
      "Edit(docs/**)",
      "Edit(src/**)",
      "Edit(public/**)",
      "Edit(package.json)",
      "Edit(tsconfig.json)",
      "Edit(next.config.*)",
      "Edit(tailwind.config.*)",
      "Edit(postcss.config.*)",
      "Edit(.gitignore)",
      "Edit(README.md)",
      "Write(content/**)",
      "Write(docs/**)",
      "Write(src/**)",
      "Write(public/**)",
      "Bash(npm install*)",
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(git status*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git remote*)",
      "Bash(git init)"
    ]
  }
}
