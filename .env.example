# Copy to .env.local and fill in. NEVER commit real values — .env* is gitignored
# (this .env.example is the one tracked exception).

# Google Apps Script Web App URL that receives form submissions and appends them
# to the Google Sheet. See docs/apps-script-endpoint.js for how to deploy and
# obtain this URL. Read ONLY server-side (route handlers) — it must never be
# exposed to the browser, so do NOT prefix it with NEXT_PUBLIC_.
GOOGLE_SHEETS_WEBHOOK_URL=
